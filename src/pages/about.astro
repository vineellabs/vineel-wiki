---
import Base from '../layouts/Base.astro';
---
<Base title="About">
  <div class="about-wrap">
    <div class="about-eyebrow">About this space</div>
    <h1 class="about-title">V/WIKI</h1>
    <div class="about-body">
      <p>A personal knowledge base — talks, essays, frameworks, and raw ideas worth keeping. Less a blog, more a working memory.</p>
      <p>To add a new article, drop a <code>.md</code> file into <code>src/content/articles/</code> with this frontmatter:</p>
      <pre><code>---
title: "Your Article Title"
description: "One-line description"
date: "2026-04-24"
tags: ["tag1", "tag2"]
source: "Source Name"
sourceUrl: "https://..."
layout: "../../layouts/Article.astro"
---

Your markdown content here...</code></pre>
      <p>Push to GitHub → Vercel auto-deploys. That's the whole workflow.</p>
    </div>
  </div>
</Base>

<style>
.about-wrap { max-width: 640px; margin: 0 auto; padding: 5rem 2rem; }
.about-eyebrow {
  font-family: var(--font-mono); font-size: 0.7rem; letter-spacing: 0.2em;
  text-transform: uppercase; color: var(--accent-dim); margin-bottom: 1rem;
}
.about-title {
  font-family: var(--font-display); font-size: 3.5rem; font-weight: 700;
  color: var(--text); margin-bottom: 2.5rem;
}
.about-body p {
  font-size: 1.05rem; color: var(--text-muted); line-height: 1.75;
  margin-bottom: 1.5rem;
}
.about-body pre {
  background: var(--bg-card); border: 1px solid var(--border);
  border-radius: 4px; padding: 1.5rem; margin: 1.5rem 0;
  overflow-x: auto;
}
.about-body code {
  font-family: var(--font-mono); font-size: 0.8rem;
  color: var(--accent); line-height: 1.8;
}
.about-body p code {
  background: var(--tag-bg); padding: 0.1rem 0.4rem;
  border-radius: 2px; font-size: 0.85rem;
}
</style>
